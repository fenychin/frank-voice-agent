# ==========================================
# Frank Voice Agent - MVP Config
# ==========================================
#
# Architecture:
#   - STT: Local (faster-whisper-large-v3-turbo)
#   - LLM: MiniMax-M2.7-highspeed (cloud)
#   - TTS: Qwen3-TTS-Flash (cloud via DashScope)

# 1. MiniMax API Key (核心 - LLM)
#    Apply: https://www.minimaxi.com/
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_LLM_MODEL=MiniMax-M2.7-highspeed

# 2. DashScope API Key (TTS)
#    Apply: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_key_here
DASHSCOPE_TTS_MODEL=qwen-tts-flash

# 3. Wake Word AccessKey (Optional - Picovoice)
#    Apply: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_key_here

# 4. Server Config
SERVER_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PORT=3000